-- EXPERIMENTO FE V2: Desplazamiento por articulación (Sin muerte / Cámara fija)
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local char = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local head = char:WaitForChild("Head", 5)
local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") -- R6 / R15
local humanoid = char:WaitForChild("Humanoid", 5)

if head and torso and humanoid then
	-- STEP 1: Fijar la cámara al Torso para que no se caiga con la cabeza
	local camera = Workspace.CurrentCamera
	camera.CameraSubject = torso
	
	-- STEP 2: Re-soldar accesorios localmente al Torso (Evita calvicie)
	for _, instance in ipairs(char:GetChildren()) do
		if instance:IsA("Accessory") and instance:FindFirstChild("Handle") then
			local handle = instance.Handle
			
			for _, joint in ipairs(handle:GetChildren()) do
				if joint:IsA("Weld") or joint:IsA("WeldConstraint") or joint:IsA("Attachment") then
					joint:Destroy()
				end
			end
			
			local newWeld = Instance.new("WeldConstraint")
			newWeld.Part0 = handle
			newWeld.Part1 = torso
			newWeld.Parent = handle
			handle.CanCollide = false
		end
	end
	
	-- STEP 3: Modificar el cuello en lugar de destruirlo
	-- Buscamos la articulación del cuello
	local neck = head:FindFirstChild("Neck") or torso:FindFirstChild("Neck")
	
	if neck and neck:IsA("Motor6D") then
		-- Modificamos el C1 (CFrame de desfase). 
		-- Al subir el C1 localmente, el servidor replica que la cabeza se desplaza hacia ABAJO
		-- Lo dejamos a -40 studs: lo suficientemente bajo para esconder el tag, pero arriba del límite de muerte.
		neck.C1 = neck.C1 * CFrame.new(0, 40, 0)
	else
		-- Si el juego usa Welds tradicionales en vez de Motor6D:
		local alternativeNeck = head:FindFirstChildOfClass("Weld") or torso:FindFirstChildOfClass("Weld")
		if alternativeNeck then
			alternativeNeck.C1 = alternativeNeck.C1 * CFrame.new(0, 40, 0)
		end
	end
	
	-- Mantener consistencia local por si el script de animaciones intenta resetear el cuello
	RunService.Heartbeat:Connect(function()
		if neck and neck.Parent then
			neck.CurrentAngle = 0
		end
	end)
end
