-- Animaciones Hover
minusButton.MouseEnter:Connect(function() minusButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
minusButton.MouseLeave:Connect(function() minusButton.BackgroundColor3 = Color3.fromRGB(28, 28, 28) end)
