-- =============================================================================
-- LOGICA CORE: COMPROBACIONES DINÁMICAS SEGURAS (ANTI-NIL)
-- =============================================================================
local function checkVisualCone(targetPart)
	-- Búsqueda segura en caliente de la cabeza del bot
	local currentHead = botCharacter:FindFirstChild("Head")
	if not currentHead then return false end
	
	local botToTarget = (targetPart.Position - currentHead.Position)
	local distance = botToTarget.Magnitude
	
	if distance > BotSettings.ViewDistance then return false end
	
	local botLookDirection = currentHead.CFrame.LookVector
	local directionToTarget = botToTarget.Unit
	local dotProduct = botLookDirection:Dot(directionToTarget)
	local angle = math.acos(dotProduct) * (180 / math.pi)
	
	if angle <= (BotSettings.FieldOfView / 2) then
		local raycastParams = RaycastParams.new()
		raycastParams.FilterDescendantsInstances = {botCharacter}
		raycastParams.FilterType = Enum.RaycastFilterType.Exclude
		
		local raycastResult = Workspace:Raycast(currentHead.Position, botToTarget, raycastParams)
		if raycastResult and raycastResult.Instance:IsDescendantOf(targetPart.Parent) then
			return true 
		end
	end
	return false
end

local function scanTargets()
	if not getgenv().BotMaster_VisualActive then return nil end
	for _, player in ipairs(Players:GetPlayers()) do
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
			if char.Humanoid.Health > 0 and player ~= localPlayer then
				if checkVisualCone(char.HumanoidRootPart) then
					return char
				end
			end
		end
	end
	return nil
end

local function executePatrol()
	-- Búsqueda en caliente de componentes motrices
	local currentTorso = botCharacter:FindFirstChild("Torso") or botCharacter:FindFirstChild("UpperTorso")
	local currentHumanoid = botCharacter:FindFirstChildOfClass("Humanoid")
	
	if not currentTorso or not currentHumanoid then return end
	
	if #BotSettings.PatrolNodes == 0 then
		local basePos = currentTorso.Position
		BotSettings.PatrolNodes = {
			basePos + Vector3.new(20, 0, 0),
			basePos + Vector3.new(20, 0, 20),
			basePos + Vector3.new(0, 0, 20),
			basePos + Vector3.new(0, 0, 0)
		}
	end

	local targetNodePos = BotSettings.PatrolNodes[currentNodeIndex]
	if targetNodePos then
		currentHumanoid:MoveTo(targetNodePos)
		local distanceToNode = (currentTorso.Position - targetNodePos).Magnitude
		if distanceToNode <= BotSettings.AcceptanceRadius then
			currentNodeIndex = currentNodeIndex + 1
			if currentNodeIndex > #BotSettings.PatrolNodes then
				currentNodeIndex = 1
			end
		end
	end
end

-- HILO PRINCIPAL: MÁQUINA DE ESTADOS ASÍNCRONA
task.spawn(function()
	while task.wait(BotSettings.CheckRate) do
		local currentHumanoid = botCharacter:FindFirstChildOfClass("Humanoid")
		
		if getgenv().BotMaster_SystemActive and currentHumanoid and currentHumanoid.Health > 0 then
			local detectedTarget = scanTargets()
			
			if detectedTarget then
				currentTarget = detectedTarget
				currentBotState = BotStates.CHASE
			else
				if currentBotState == BotStates.CHASE then
					currentTarget = nil
					currentBotState = BotStates.PATROL
				end
			end
			
			-- Fase de ejecución de acciones
			if currentBotState == BotStates.CHASE and currentTarget and currentTarget:FindFirstChild("HumanoidRootPart") then
				currentHumanoid:MoveTo(currentTarget.HumanoidRootPart.Position)
			elseif currentBotState == BotStates.PATROL then
				executePatrol()
			end
		else
			-- Parada de emergencia si el Core está inactivo o el bot cayó inconsciente
			if currentHumanoid then 
				currentHumanoid:Move(Vector3.new(0,0,0)) 
			end
		end
	end
end)

