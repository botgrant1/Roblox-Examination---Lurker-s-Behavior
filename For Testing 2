-- BOT BEHAVIOR V5.3: PROTO-PERCEPCIÓN VISUAL (RAYCAST CONE)
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local BotConfig = {
	ViewDistance = 60,       -- Qué tan lejos ve el bot (en studs)
	FieldOfView = 90,        -- Ángulo del cono de visión (90 grados al frente)
	CheckRate = 0.1,         -- Cada cuánto tiempo escanea (0.1s evita tirones por Raycast)
}

local botCharacter = script.Parent -- Asumiendo que el script está dentro del modelo del bot
local botHead = botCharacter:WaitForChild("Head")
local botHumanoid = botCharacter:WaitForChild("Humanoid")

getgenv().VisualSystem_Active = true

-- Función matemática para validar si un objetivo está en el cono visual
local function isTargetInCone(targetPart)
	local botToTarget = (targetPart.Position - botHead.Position)
	local distance = botToTarget.Magnitude
	
	-- 1. Filtro rápido: ¿Está dentro del rango de distancia?
	if distance > BotConfig.ViewDistance then return false end
	
	-- 2. Filtro rápido: ¿Está en el ángulo correcto al frente?
	local botLookDirection = botHead.CFrame.LookVector
	local directionToTarget = botToTarget.Unit
	
	-- Calculamos el ángulo usando el producto punto (Dot Product)
	local dotProduct = botLookDirection:Dot(directionToTarget)
	local angle = math.acos(dotProduct) * (180 / math.pi) -- Convertimos a grados
	
	if angle <= (BotConfig.FieldOfView / 2) then
		-- 3. Si pasa los filtros matemáticos, tiramos EL ÚNICO Raycast para validar obstrucciones (paredes)
		local raycastParams = RaycastParams.new()
		raycastParams.FilterDescendantsInstances = {botCharacter} -- El bot no se choca a sí mismo
		raycastParams.FilterType = Enum.RaycastFilterType.Exclude
		
		local raycastResult = Workspace:Raycast(botHead.Position, botToTarget, raycastParams)
		
		if raycastResult then
			-- Si el rayo choca con algo, validamos si es parte del personaje objetivo
			if raycastResult.Instance:IsDescendantOf(targetPart.Parent) then
				return true -- ¡LÍNEA DE VISIÓN LIMPIA! El bot te está viendo
			end
		end
	end
	
	return false
end

-- Bucle de escaneo optimizado
task.spawn(function()
	while getgenv().VisualSystem_Active and task.wait(BotConfig.CheckRate) do
		local targetFound = nil
		
		-- Buscamos jugadores en el mapa
		for _, player in ipairs(Players:GetPlayers()) do
			local char = player.Character
			if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
				-- Validamos que el jugador no esté muerto
				if char.Humanoid.Health > 0 then
					if isTargetInCone(char.HumanoidRootPart) then
						targetFound = char
						break -- Prioriza al primer objetivo que ve
					end
				end
			end
		end
		
		-- Manejo de estados según la percepción
		if targetFound then
			print("BOT STATE: [OVERRIDE] - Objetivo detectado: " .. targetFound.Name)
			-- Aquí conectarías tu sistema de persecución (ej. botHumanoid:MoveTo(targetFound.HumanoidRootPart.Position))
		else
			-- Si no ve a nadie, sigue con su comportamiento de patrullaje base
			-- print("BOT STATE: [PATROL] - Escaneando...")
		end
	end
end)
